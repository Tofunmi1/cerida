#!/bin/sh
# Pre-commit hook: run fmt and clippy before every commit.
# Skip with: git commit --no-verify

set -e

KEYS="$(git rev-parse --show-toplevel)/circuits/keys"

echo "→ cargo fmt --all -- --check"
cargo fmt --all -- --check

echo "→ cargo clippy (workspace)"
VK_COMMIT_JSON="$KEYS/order_commitment_vk.json" \
VK_CANCEL_JSON="$KEYS/order_cancel_vk.json" \
VK_MATCH_JSON="$KEYS/order_match_vk.json" \
VK_NOTE_SPEND_JSON="$KEYS/note_spend_vk.json" \
  cargo clippy --all-targets -- -D warnings

echo "→ cargo clippy (rust-circuits)"
cargo clippy --all-targets --manifest-path tools/rust-circuits/Cargo.toml -- -D warnings
